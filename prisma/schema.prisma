// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}

model ocr {
  id              Int           @id @default(autoincrement())
  //add vendor name 
  A_weight        Int
  B_weight        Int
  challan         String
  address         String
  map_url         String
  latitude        Float
  longitude       Float
  delivery_date   DateTime
  delivery_status String
  net_weight      Int
  tare_weight     Int
  gross_weight    Int
  vehicle_number  String
  date            DateTime
  created_at      DateTime      @default(now())
  e_way_bill      String        @default("")
  vender          vendorDetail? @relation(fields: [vendorDetailId], references: [id])
  vendorDetailId  Int?
}

model challan {
  id       Int @id @default(autoincrement())
  starting Int
  ending   Int
}

model companyDetail {
  id              Int    @id @default(autoincrement())
  shotName        String // BTE
  name            String
  billingAddress  String
  gstNo           String
  shippingAddress String
}

model vendorDetail {
  id   Int    @id @default(autoincrement())
  name String
  ocr  ocr[]
}

model mis {
  id       Int    @id @default(autoincrement())
  sheetURL String
}

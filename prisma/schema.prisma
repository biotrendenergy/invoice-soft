// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js" // here do not use the new client (prisma-client)
  binaryTargets = ["native", "linux-musl", "rhel-openssl-3.0.x"] // first one is for cross-platform, second one for docker, last one for serverless environment. safe to include all
  output        = "../src/generated/prisma" // it is better to include the generator inside `src/` or `app/` if `src/` not available.
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}

model ocr {
  id                 Int            @id @default(autoincrement())
  //add vendor name 
  A_weight           Int
  B_weight           Int
  challan            String
  address            String
  map_url            String
  latitude           Float
  longitude          Float
  delivery_date      DateTime
  delivery_status    String
  net_weight         Int
  tare_weight        Int
  gross_weight       Int
  vehicle_number     String
  date               DateTime
  created_at         DateTime       @default(now())
  e_way_bill         String         @default("")
  e_way_bill_date    DateTime       @default(now())
  e_way_bill_gst     String         @default("")
  e_way_bill_bill_to String?
  e_way_bill_ship_to String?
  vendor             vendorDetail?  @relation(fields: [vendorDetailId], references: [id])
  vendorDetailId     Int?
  company            companyDetail? @relation(fields: [companyDetailId], references: [id])
  companyDetailId    Int?
  medias             media[]

  mis mis?
}

model challan {
  id       Int @id @default(autoincrement())
  starting Int
  ending   Int
}

model companyDetail {
  id              Int     @id @default(autoincrement())
  shotName        String // BTE
  name            String
  billingAddress  String
  billingState    String
  billing_gstNo   String
  shipping_gstNo  String
  shippingAddress String
  shippingState   String
  stringNumber    String
  PONumber        String  @default("")
  sheetUrl        String?

  ocr       ocr[]
  debitNote debitNote[]
}

model vendorDetail {
  id        Int         @id @default(autoincrement())
  name      String
  address   String?
  gst       String?
  state     String?
  ocr       ocr[]
  debitNote debitNote[]
}

model mis {
  id    Int @id @default(autoincrement())
  ocr   ocr @relation(fields: [ocrId], references: [id])
  ocrId Int @unique
}

model debitNote {
  id                 Int           @id @default(autoincrement())
  party_challan      String
  bte_challan        String
  venderChallan      String
  createAt           DateTime      @default(now())
  e_way_bill_ship_to String?
  isIgst             Boolean
  igst               Float
  sgst               Float
  cgst               Float
  rate               Int
  quntity            Int
  amount             Float
  shipTo             companyDetail @relation(fields: [companyDetailId], references: [id])
  billTo             vendorDetail  @relation(fields: [vendorDetailId], references: [id])
  companyDetailId    Int
  vendorDetailId     Int
}

model media {
  id      Int    @id @default(autoincrement())
  title   String
  content String
  type    String
  ocr     ocr?   @relation(fields: [ocrId], references: [id])
  ocrId   Int?
}

model audit {
  id       Int      @id @default(autoincrement())
  message  String
  ip       String
  createAt DateTime @default(now())
}

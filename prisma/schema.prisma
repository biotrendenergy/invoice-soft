// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model user {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}

model ocr {
  id              Int            @id @default(autoincrement())
  //add vendor name 
  A_weight        Int
  B_weight        Int
  challan         String
  address         String
  map_url         String
  latitude        Float
  longitude       Float
  delivery_date   DateTime
  delivery_status String
  net_weight      Int
  tare_weight     Int
  gross_weight    Int
  vehicle_number  String
  date            DateTime
  created_at      DateTime       @default(now())
  e_way_bill      String         @default("")
  e_way_bill_date DateTime       @default(now())
  vendor          vendorDetail?  @relation(fields: [vendorDetailId], references: [id])
  vendorDetailId  Int?
  company         companyDetail? @relation(fields: [companyDetailId], references: [id])
  companyDetailId Int?
  medias          media[]
}

model challan {
  id       Int @id @default(autoincrement())
  starting Int
  ending   Int
}

model companyDetail {
  id              Int    @id @default(autoincrement())
  shotName        String // BTE
  name            String
  billingAddress  String
  billingState    String
  billing_gstNo   String
  shipping_gstNo  String
  shippingAddress String
  shippingState   String
  stringNumber    String
  PONumber        String @default("")

  ocr ocr[]
}

model vendorDetail {
  id   Int    @id @default(autoincrement())
  name String
  ocr  ocr[]
}

model mis {
  id        Int    @id @default(autoincrement())
  sheetURL  String
  rowNumber String
}

model debitNote {
  id Int @id @default(autoincrement())
}

model media {
  id      Int    @id @default(autoincrement())
  title   String
  content String
  type    String
  ocr     ocr?   @relation(fields: [ocrId], references: [id])
  ocrId   Int?
}

model audit {
  id       Int      @id @default(autoincrement())
  message  String
  ip       String
  createAt DateTime @default(now())
}
